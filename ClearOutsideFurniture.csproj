    </Reference>
    <Reference Include="UnityEngine.InputModule">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\UnityEngine.InputModule.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Kitchen">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\Kitchen.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="KitchenMods">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\KitchenMods.dll</HintPath>
      <Private>False</Private>
    </Reference>
  </ItemGroup>

  <Target Name="CopyToModsFolder" AfterTargets="Build">
    <MakeDir Directories="$(PlateUpDir)\Mods\$(AssemblyName)" />
    <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(PlateUpDir)\Mods\$(AssemblyName)" />
  </Target>

</Project>
