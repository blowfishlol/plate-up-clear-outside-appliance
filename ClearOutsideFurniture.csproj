<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <AssemblyName>ClearOutsideFurniture</AssemblyName>
    <RootNamespace>ClearOutsideFurniture</RootNamespace>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>

  <PropertyGroup>
    <!-- 
      Set your PlateUp installation directory here.
      You can also set this as an environment variable PLATEUP_DIR
      Common locations:
        Windows: C:\Program Files (x86)\Steam\steamapps\common\PlateUp\PlateUp
        Linux: ~/.steam/steam/steamapps/common/PlateUp/PlateUp
    -->
    <PlateUpDir Condition="'$(PLATEUP_DIR)' != ''">$(PLATEUP_DIR)</PlateUpDir>
    <PlateUpDir Condition="'$(PLATEUP_DIR)' == ''">C:\Program Files (x86)\Steam\steamapps\common\PlateUp\PlateUp</PlateUpDir>
  </PropertyGroup>

  <ItemGroup>
    <!-- PlateUp Game References -->
    <Reference Include="Kitchen.Common">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\Kitchen.Common.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Kitchen.FranchiseBuilderMode">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\Kitchen.FranchiseBuilderMode.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Kitchen.FranchiseMode">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\Kitchen.FranchiseMode.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Kitchen.GameData">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\Kitchen.GameData.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Kitchen.Layouts">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\Kitchen.Layouts.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Kitchen.MessagePack">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\Kitchen.MessagePack.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Kitchen.MessagePack.Generated">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\Kitchen.MessagePack.Generated.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Kitchen.Networking">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\Kitchen.Networking.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Kitchen.Persistence">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\Kitchen.Persistence.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Kitchen.PostgameMode">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\Kitchen.PostgameMode.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Kitchen.ResearchMode">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\Kitchen.ResearchMode.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Kitchen.RestaurantMode">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\Kitchen.RestaurantMode.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Kitchen.ServiceCreator">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\Kitchen.ServiceCreator.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Kitchen.TutorialMode">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\Kitchen.TutorialMode.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="KitchenMode">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\KitchenMode.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Unity.Entities">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\Unity.Entities.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Unity.Collections">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\Unity.Collections.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Unity.Collections.LowLevel.ILSupport">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\Unity.Collections.LowLevel.ILSupport.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Unity.InputSystem">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\Unity.InputSystem.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Unity.InputSystem.ForUI">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\Unity.InputSystem.ForUI.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Unity.InputSystem.RebindingUI">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\Unity.InputSystem.RebindingUI.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Unity.Mathematics">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\Unity.Mathematics.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Unity.Mathematics.Extensions">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\Unity.Mathematics.Extensions.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Unity.Mathematics.Extensions.Hybrid">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\Unity.Mathematics.Extensions.Hybrid.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="UnityEngine.CoreModule">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\UnityEngine.CoreModule.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="UnityEngine.InputLegacyModule">
      <HintPath>$(PlateUpDir)\PlateUp_Data\Managed\UnityEngine.InputLegacyModule.dll</HintPath>
